# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Environment files (never commit real secrets) ─────────────────────────────
.env
frontend/.env
backend/.env
.env.local
.env.*.local

# ── Vite build output ─────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# ── VS Code personal settings (keep launch/extensions configs) ────────────────
.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
