# Copy this file to .env and fill in your real values.
# Never commit .env — it is listed in .gitignore.

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/safex_portal
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/safex_portal?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/safex_portal

# Port the Express API listens on
PORT=5000

# Frontend origin allowed by CORS (must match your Vite dev server URL exactly)
CLIENT_ORIGIN=http://localhost:5173
